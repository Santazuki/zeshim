{
  "name": "@unblind/zeshi",
  "version": "0.1.0",
  "description": "Zero-dependency, API Shim, Harmonized. 协议驱动 + 零依赖的 LLM Provider 垫片层",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "llm", "provider", "anthropic", "openai", "gemini",
    "agent", "skill", "claude-code", "protocol",
    "zero-dependency", "typescript"
  ],
  "engines": { "node": ">=18" },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
